# GranjaTech Rust Backend - Environment Variables
# Copie para .env e ajuste os valores

# PostgreSQL (formato SQLx)
DATABASE_URL=postgres://postgres:123456@localhost:5432/GranjaTechDb

# JWT Configuration (mesmos valores do .NET appsettings.json)
JWT_KEY=74b9f1d2-a3e9-4f7c-a9d8-9e2c1a3b5d7e-granjatech-super-secret
JWT_ISSUER=GranjaTechAPI
JWT_AUDIENCE=GranjaTechApp

# CORS - Origins separadas por ponto e virgula
ALLOWED_ORIGINS=http://localhost:3000;http://localhost:80

# Swagger
SWAGGER_ENABLED=true

# Log level (tracing env filter)
RUST_LOG=info
